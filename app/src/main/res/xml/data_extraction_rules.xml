<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules – BugList
    Prevents all sensitive data from being extracted via cloud backup or D2D transfer.
    All database files and DataStore preferences are excluded.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
