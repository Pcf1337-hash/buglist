<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup Rules – BugList (legacy API 30 and below)
    All data is excluded from backup to protect encrypted content.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
