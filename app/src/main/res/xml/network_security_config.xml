<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config – BugList
    App is offline-first. Cleartext is forbidden as defense in depth.
    Even if no network calls are made, we explicitly forbid cleartext.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
