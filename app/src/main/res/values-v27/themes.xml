<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        API 27+ override: windowLightNavigationBar is only available from API 27.
        Forces dark navigation bar icons (false = light icons on dark background).
    -->
    <style name="Theme.BugList" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
